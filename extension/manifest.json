{
  "manifest_version": 3,
  "name": "DemoReel Recorder",
  "version": "1.0.0",
  "description": "One-click screen recorder for DemoReel — record your product, generate a polished demo video.",
  "permissions": ["desktopCapture", "storage", "tabs", "activeTab", "scripting"],
  "host_permissions": ["https://demoreel-production.up.railway.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "DemoReel — Record & Generate Demo Videos"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
