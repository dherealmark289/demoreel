{
  "manifest_version": 3,
  "name": "DemoReel Recorder",
  "version": "1.0.0",
  "description": "One-click screen recorder for DemoReel — record your product, generate a polished demo video.",
  "permissions": ["desktopCapture", "storage", "tabs", "activeTab", "scripting"],
  "host_permissions": ["https://demoreel-production.up.railway.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "DemoReel Recorder"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
